// Prisma Schema for FOLK Spiritual Gems CRM
// PostgreSQL Database (production on Railway)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Users Table
model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String   @default("")
  password      String?  // bcrypt hashed
  role          String   @default("[]") // JSON array
  photoUrl      String?
  createdAt     DateTime @default(now())
  fgCode        String?
  reportsTo     String?  // JSON
  pausedCallingSession String? // JSON
  whatsappTemplate String?

  // Relations
  ownedGroups        Group[]           @relation("GroupOwner")
  createdCallingSessions CallingSession[] @relation("SessionCreator")
  assignedCallingSessions CallingSession[] @relation("SessionAssigner")
  folkGuideSessions  CallingSession[] @relation("FolkGuideSessions")
  notifications      Notification[]
  peopleAsEnabler    Person[]          @relation("EnablerRelation")
  peopleAsFolkGuide  Person[]          @relation("FolkGuideRelation")
  peopleAsCoEnabler  Person[]          @relation("CoEnablerRelation")

  @@map("users")
}

// People (Contacts) Table
model Person {
  id            String   @id @default(uuid())
  fullName      String   @default("Unknown Contact")
  fullNameLowercase String @default("")
  phone         String
  photoUrl      String?
  age           Int      @default(0)
  currentFolkStage String @default("FreshLead")
  location      String?
  stayingWith   String?
  occupation    String?
  organisation  String?
  rentDetails   Float    @default(0)
  nativePlace   String?
  sgRating      Float    @default(0)
  contactSource String   @default("[]") // JSON array
  chantingStatus Int     @default(0)
  fromOtherCamp Boolean  @default(false)
  enablerInTouchWith String @default("")
  enablerId     String?
  folkGuide     String   @default("")
  folkGuideId   String?
  folkId        String   @default("")
  createdAt     DateTime @default(now())
  progress      String   @default("[]") // JSON ProgressCategory[]
  generalRemarks String?
  callHistory   String   @default("[]") // JSON CallLog[]
  attendanceHistory String @default("[]") // JSON AttendanceEntry[]
  relationshipStatus String @default("Single")
  verifiedByFg  String   @default("No")
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  lastCallAt    DateTime?
  lastCallStatus String?
  lastCallRemark String?
  lastSyncTimestamp BigInt?
  lastSg        String?
  lastMa        String?
  lastFrp       String?
  nextFollowUpAt String?
  reminderSetName String?
  activeCoEnablerSessionId String?
  coEnablerId   String?
  coEnablerName String?
  coEnablerExpiry String?
  customData    String   @default("{}") // JSON

  // Relations
  enabler       User?    @relation("EnablerRelation", fields: [enablerId], references: [id])
  folkGuideUser User?    @relation("FolkGuideRelation", fields: [folkGuideId], references: [id])
  coEnabler     User?    @relation("CoEnablerRelation", fields: [coEnablerId], references: [id])
  groupMembers  GroupMember[]
  attendance    Attendance[]
  sessions      CallingSessionPerson[]

  @@index([phone])
  @@index([fullNameLowercase])
  @@index([enablerId])
  @@index([folkGuideId])
  @@index([currentFolkStage])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([lastCallAt])
  @@index([nextFollowUpAt])
  @@map("people")
}

// Groups Table
model Group {
  id            String   @id @default(uuid())
  name          String
  description   String?
  photoUrl      String?
  createdBy     String?
  createdByName String   @default("")
  creatorRole   String   @default("[]") // JSON array
  sharedWithUserIds String @default("[]") // JSON array
  visibility    String   @default("[]") // JSON array
  memberCount   Int      @default(0)
  isDynamic     Boolean  @default(false)
  color         String?
  expiresAt     DateTime?
  task          String?
  assignedBy    String?
  assignedByName String?
  assignedToName String?
  reportingEnabled Boolean @default(false)
  reportTime    String?
  reportRecipients String @default("[]") // JSON array

  // Relations
  owner         User?    @relation("GroupOwner", fields: [createdBy], references: [id])
  members       GroupMember[]
  events        GroupEvent[]
  attendance    Attendance[]

  @@map("groups")
}

// Group Members (Junction Table)
model GroupMember {
  groupId   String
  personId  String @map("contactId")

  group     Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([groupId, personId])
  @@map("group_members")
}

// Group Events Table
model GroupEvent {
  id            String   @id @default(uuid())
  groupId       String
  name          String
  date          String
  createdAt     DateTime @default(now())
  linkInfo      String?  // JSON
  attendeeCount Int      @default(0)

  // Relations
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendance    Attendance[]

  @@map("group_events")
}

// Attendance Table
model Attendance {
  id        String   @id @default(uuid())
  personId  String
  groupId   String
  eventId   String?
  markedAt  DateTime @default(now())
  date      String

  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  event     GroupEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([personId, eventId])
  @@map("attendance")
}

// Calling Sessions Table
model CallingSession {
  id            String   @id @default(uuid())
  name          String
  current_index Int      @default(0)
  status        String   @default("active")
  createdBy     String
  creatorName   String   @default("")
  assignedById  String?
  assignedByName String  @default("")
  folkGuideId   String?
  lastActivity  DateTime @default(now())
  createdAt     DateTime @default(now())
  coEnablerIds  String   @default("[]") // JSON array

  // Relations
  creator       User     @relation("SessionCreator", fields: [createdBy], references: [id])
  assigner      User?    @relation("SessionAssigner", fields: [assignedById], references: [id])
  folkGuide     User?    @relation("FolkGuideSessions", fields: [folkGuideId], references: [id])
  people        CallingSessionPerson[]

  @@index([status])
  @@index([createdBy])
  @@index([folkGuideId])
  @@index([lastActivity])
  @@map("calling_sessions")
}

// Calling Session People (Junction Table)
model CallingSessionPerson {
  id          String @id @default(uuid())
  sessionId   String
  personId    String

  session     CallingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  person      Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([sessionId, personId])
  @@map("calling_session_people")
}

// Co-Enabler Sessions Table
model CoEnablerSession {
  id            String   @id @default(uuid())
  name          String
  task          String   @default("")
  type          String   @default("external")
  expiresAt     DateTime
  creatorId     String?
  creatorName   String   @default("")
  peopleIds     String   @default("[]") // JSON array

  @@map("co_enabler_sessions")
}

// Settings Table (Single Document)
model Setting {
  id            String   @id @default("options")
  contactSources String  @default("[]") // JSON array
  folkStages    String   @default("[]") // JSON array
  occupationStatuses String @default("[]") // JSON array
  stayingWithOptions String @default("[]") // JSON array
  customPersonFields String @default("[]") // JSON array
  sgOptions     String   @default("[]") // JSON array
  maOptions     String   @default("[]") // JSON array
  frpOptions    String   @default("[]") // JSON array
  activityFieldLabels String @default("{}") // JSON

  @@map("settings")
}

// Audit Logs Table
model Audit {
  id        String   @id @default(uuid())
  userId    String   @default("system")
  userName  String   @default("System")
  action    String
  details   String   @default("")
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@map("audits")
}

// Mail Queue Table
model Mail {
  id        String   @id @default(uuid())
  to        String   // JSON array of email addresses
  subject   String
  html      String
  createdAt DateTime @default(now())

  @@map("mail")
}

// Notifications Table
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  timestamp DateTime @default(now())
  isRead    Boolean  @default(false)
  type      String   @default("info")
  senderId  String?
  senderName String?
  personId  String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@index([isRead])
  @@map("notifications")
}
