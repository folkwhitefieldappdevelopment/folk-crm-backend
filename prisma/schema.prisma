generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @default("")
  password  String?
  role      String   @default("[]")
  photoUrl  String?
  createdAt DateTime @default(now())
  fgCode    String?
  reportsTo String?
  pausedCallingSession String?
  whatsappTemplate String?

  ownedGroups            Group[]              @relation("GroupOwner")
  createdCallingSessions CallingSession[]     @relation("SessionCreator")
  assignedCallingSessions CallingSession[]    @relation("SessionAssigner")
  folkGuideSessions      CallingSession[]    @relation("FolkGuideSessions")
  notifications          Notification[]
  peopleAsEnabler        Person[]             @relation("EnablerRelation")
  peopleAsFolkGuide      Person[]             @relation("FolkGuideRelation")
  callingSessionEnablers CallingSessionEnabler[]
  assignedGroups         Group[]              @relation("GroupAssigner")
  sharedGroups           GroupSharedUser[]
  @@map("users")
}

model Person {
  id            String   @id @default(uuid())
  fullName      String   @default("Unknown Contact")
  phone         String
  photoUrl      String?
  age           Int      @default(0)
  currentFolkStage String @default("FreshLead")
  location      String?
  stayingWith   String?
  occupation    String?
  organisation  String?
  rentDetails   Float    @default(0)
  nativePlace   String?
  sgRating      Float    @default(0)
  chantingStatus Int     @default(0)
  fromOtherCamp Boolean  @default(false)
  enablerInTouchWith String @default("")
  enablerId     String?
  folkGuide     String   @default("")
  folkGuideId   String?
  folkId        String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  generalRemarks String?
  relationshipStatus String @default("Single")
  verifiedByFg  String   @default("No")
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  lastCallAt    DateTime?
  lastCallStatus String?
  lastCallRemark String?
  lastSyncTimestamp BigInt?
  lastSg        String?
  lastMa        String?
  lastFrp       String?
  nextFollowUpAt String?
  reminderSetName String?
  coEnablerSessionId String?
  customData    String   @default("{}")

  enabler       User?    @relation("EnablerRelation", fields: [enablerId], references: [id])
  folkGuideUser User?    @relation("FolkGuideRelation", fields: [folkGuideId], references: [id])
  coEnablerSession CoEnablerSession? @relation("ActiveCoEnablerSession", fields: [coEnablerSessionId], references: [id])
  groupMembers  GroupMember[]
  attendance    Attendance[]
  sessions      CallingSessionPerson[]
  callLogs      CallLog[]
  stageHistory  PersonStageHistory[]
  contactSources PersonContactSource[]
  coEnablerSessionPeople CoEnablerSessionPerson[]

  @@index([phone])
  @@index([enablerId])
  @@index([folkGuideId])
  @@index([currentFolkStage])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([lastCallAt])
  @@index([nextFollowUpAt])
  @@index([coEnablerSessionId])
  @@map("people")
}

model Group {
  id            String   @id @default(uuid())
  name          String
  description   String?
  photoUrl      String?
  createdBy     String?
  createdByName String   @default("")
  creatorRole   String   @default("[]")
  visibility    String   @default("[]")
  memberCount   Int      @default(0)
  isDynamic     Boolean  @default(false)
  color         String?
  expiresAt     DateTime?
  task          String?
  assignedById  String?
  reportingEnabled Boolean @default(false)
  reportTime    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner           User?                  @relation("GroupOwner", fields: [createdBy], references: [id])
  assigner        User?                  @relation("GroupAssigner", fields: [assignedById], references: [id])
  members         GroupMember[]
  events          GroupEvent[]
  attendance      Attendance[]
  sharedUsers     GroupSharedUser[]
  reportRecipients GroupReportRecipient[]

  @@map("groups")
}

model GroupMember {
  groupId   String
  personId  String

  group     Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([groupId, personId])
  @@map("group_members")
}

model GroupSharedUser {
  groupId String
  userId  String

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_shared_users")
}

model GroupReportRecipient {
  id      String @id @default(uuid())
  groupId String
  email   String

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_report_recipients")
}

model GroupEvent {
  id            String   @id @default(uuid())
  groupId       String
  name          String
  date          String
  createdAt     DateTime @default(now())
  linkInfo      String?
  attendeeCount Int      @default(0)

  group      Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendance Attendance[]

  @@map("group_events")
}

model Attendance {
  id        String   @id @default(uuid())
  personId  String
  groupId   String
  eventId   String?
  markedAt  DateTime @default(now())
  date      String

  person    Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  event     GroupEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([personId, eventId])
  @@index([personId, eventId])
  @@index([markedAt])
  @@map("attendance")
}

model CallLog {
  id          String   @id @default(uuid())
  personId    String
  sessionId   String?
  calledAt    DateTime @default(now())
  status      String
  remark      String?
  calledBy    String?

  person      Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([calledAt])
  @@map("call_logs")
}

model PersonStageHistory {
  id        String   @id @default(uuid())
  personId  String
  stage     String
  note      String?
  changedAt DateTime @default(now())
  changedBy String?

  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@map("person_stage_history")
}

model ContactSource {
  id   String @id @default(uuid())
  name String @unique

  people PersonContactSource[]

  @@map("contact_sources")
}

model PersonContactSource {
  personId        String
  contactSourceId String

  person          Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  contactSource   ContactSource @relation(fields: [contactSourceId], references: [id], onDelete: Cascade)

  @@id([personId, contactSourceId])
  @@map("person_contact_sources")
}

model CallingSession {
  id            String   @id @default(uuid())
  name          String
  current_index Int      @default(0)
  status        String   @default("active")
  createdBy     String
  creatorName   String   @default("")
  assignedById  String?
  assignedByName String  @default("")
  folkGuideId   String?
  lastActivity  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator       User     @relation("SessionCreator", fields: [createdBy], references: [id])
  assigner      User?    @relation("SessionAssigner", fields: [assignedById], references: [id])
  folkGuide     User?    @relation("FolkGuideSessions", fields: [folkGuideId], references: [id])
  people        CallingSessionPerson[]
  enablers      CallingSessionEnabler[]

  @@index([status])
  @@index([createdBy])
  @@index([folkGuideId])
  @@index([lastActivity])
  @@map("calling_sessions")
}

model CallingSessionPerson {
  id        String @id @default(uuid())
  sessionId String
  personId  String

  session   CallingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  person    Person         @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([sessionId, personId])
  @@map("calling_session_people")
}

model CallingSessionEnabler {
  sessionId String
  userId    String

  session   CallingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@map("calling_session_enablers")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String   @default("expo")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("push_tokens")
}

model CoEnablerSession {
  id          String   @id @default(uuid())
  name        String
  task        String   @default("")
  type        String   @default("external")
  expiresAt   DateTime
  creatorId   String?
  creatorName String   @default("")

  people      CoEnablerSessionPerson[]
  activePeople Person[]                 @relation("ActiveCoEnablerSession")

  @@map("co_enabler_sessions")
}

model CoEnablerSessionPerson {
  sessionId String
  personId  String

  session   CoEnablerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  person    Person           @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([sessionId, personId])
  @@map("co_enabler_session_people")
}

model Setting {
  id                  String @id @default("options")
  contactSources      String @default("[]")
  folkStages          String @default("[]")
  occupationStatuses  String @default("[]")
  stayingWithOptions  String @default("[]")
  customPersonFields  String @default("[]")
  sgOptions           String @default("[]")
  maOptions           String @default("[]")
  frpOptions          String @default("[]")
  activityFieldLabels String @default("{}")

  @@map("settings")
}

model Audit {
  id        String   @id @default(uuid())
  userId    String   @default("system")
  userName  String   @default("System")
  action    String
  details   String   @default("")
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@map("audits")
}

model Mail {
  id        String   @id @default(uuid())
  to        String
  subject   String
  html      String
  createdAt DateTime @default(now())

  @@map("mail")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  timestamp  DateTime @default(now())
  isRead     Boolean  @default(false)
  type       String   @default("info")
  senderId   String?
  senderName String?
  personId   String?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@index([isRead])
  @@map("notifications")
}
